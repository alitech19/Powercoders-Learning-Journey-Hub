# Render — TESTER deploy (DEBUG=True — copy into Render Environment Group)
# Replace your-app with your real *.onrender.com hostname. Do not commit real secrets.
# NOT for production. See docs/DEPLOY.md

DEBUG=True
SECRET_KEY=generate-a-long-random-string-here
ALLOWED_HOSTS=your-app.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
SITE_URL=https://your-app.onrender.com

# Postgres — option A (easiest): link DB in Render → copy Internal Database URL:
# DATABASE_URL=postgresql://user:pass@dpg-xxxxx-a/dbname
# Option B: set each field (Internal hostname, NOT localhost):
# POSTGRES_DB=  POSTGRES_USER=  POSTGRES_PASSWORD=  POSTGRES_HOST=dpg-xxxxx-a  POSTGRES_PORT=5432

# From Render Redis (Internal URL)
REDIS_URL=
CELERY_BROKER_URL=
# Render small Background Worker: use 1 (default Celery prefork ≈ 16 processes → OOM restart loop)
CELERY_WORKER_CONCURRENCY=1

DEFAULT_FROM_EMAIL=noreply@powercoders.org
# DEBUG=True forces console email — messages appear in Render web/worker logs
# Slack: configure after deploy via Administration → Slack integration

# Create the admin (and other users) manually after deploy — Render Shell:
#   cd backend && python manage.py createsuperuser

# Render free tier: no pre-deploy — use Start command or scripts/render-web-start.sh (see docs/DEPLOY.md)
