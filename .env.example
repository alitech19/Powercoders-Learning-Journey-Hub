DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Render / staging (DEBUG=False): your-app.onrender.com and https://your-app.onrender.com
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

POSTGRES_DB=powerhub
POSTGRES_USER=powerhub
POSTGRES_PASSWORD=powerhub
# Docker Compose service name — use localhost when running manage.py on the host (see docs/TESTING.md)
# Local: leave DATABASE_URL unset. Render: use DATABASE_URL or POSTGRES_* (see .env.render-test.example)
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# --- Email ---
# Local dev: console backend (emails print to terminal, never sent)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@powercoders.org
SITE_URL=http://localhost:8000

# Production SMTP — switch EMAIL_BACKEND and fill in credentials for real delivery.
#
# SendGrid:
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST=smtp.sendgrid.net
#   EMAIL_PORT=587
#   EMAIL_HOST_USER=apikey
#   EMAIL_HOST_PASSWORD=<your SendGrid API key>
#   EMAIL_USE_TLS=True
#
# Postmark:
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST=smtp.postmarkapp.com
#   EMAIL_PORT=587
#   EMAIL_HOST_USER=<your Postmark server token>
#   EMAIL_HOST_PASSWORD=<your Postmark server token>
#   EMAIL_USE_TLS=True

# Sentry error monitoring (optional; leave empty in dev)
# Create a free project at https://sentry.io, then paste the DSN here.
# Only active when SENTRY_DSN is set — safe to leave blank locally.
SENTRY_DSN=

# --- Database backups ---
# Weekly pg_dump → gzip → S3-compatible storage. Leave blank to disable.
#
# AWS S3:
#   BACKUP_S3_BUCKET=powerhub-backups
#   BACKUP_S3_ACCESS_KEY=<access key id>
#   BACKUP_S3_SECRET_KEY=<secret access key>
#   BACKUP_S3_REGION=eu-central-1
#
# Backblaze B2 (S3-compatible, cheaper):
#   BACKUP_S3_BUCKET=powerhub-backups
#   BACKUP_S3_ACCESS_KEY=<keyID>
#   BACKUP_S3_SECRET_KEY=<applicationKey>
#   BACKUP_S3_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
#
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_ENDPOINT_URL=
BACKUP_S3_REGION=us-east-1
BACKUP_RETENTION_DAYS=30

# --- Production (DEBUG=False on Render/staging) ---
# Enables HTTPS redirect, HSTS, secure cookies, and proxy SSL header automatically.
# Use a strong SECRET_KEY (app refuses django-insecure-* defaults when DEBUG=False).
# Configure SMTP (see the Email section above) so real users actually receive their
# welcome email (with temp password) and password-reset emails.
#
#   DEBUG=False
#   SECRET_KEY=<python -c "import secrets; print(secrets.token_urlsafe(64))">
#   ALLOWED_HOSTS=your-app.onrender.com
#   CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
#
# Optional overrides (defaults shown):
#   SECURE_SSL_REDIRECT=True
#   SECURE_HSTS_SECONDS=31536000
