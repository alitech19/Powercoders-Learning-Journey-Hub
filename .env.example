# ============================================================
# REQUIRED — core app settings
# ============================================================

SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (PostgreSQL)
POSTGRES_DB=powerhub
POSTGRES_USER=powerhub
POSTGRES_PASSWORD=powerhub
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ============================================================
# DEVELOPMENT — quick login and demo data
# Missing values are treated as False/disabled.
# In production set DEBUG=False and omit everything below.
# ============================================================

ENABLE_DEV_LOGIN=True

DEV_STUDENT_EMAIL=student@example.com
DEV_STUDENT_DISPLAY_NAME=Student
DEV_STUDENT_PASSWORD=student12345

DEV_TEACHER_EMAIL=teacher@example.com
DEV_TEACHER_DISPLAY_NAME=Teacher
DEV_TEACHER_PASSWORD=teacher12345

DEV_ADMIN_EMAIL=admin@example.com
DEV_ADMIN_DISPLAY_NAME=Admin
DEV_ADMIN_PASSWORD=admin12345

DEV_COHORT_NAME=Demo_Cohort
DEV_GROUP_NAME=Demo_Group
