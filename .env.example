DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

POSTGRES_DB=powerhub
POSTGRES_USER=powerhub
POSTGRES_PASSWORD=powerhub
# Docker Compose service name — use localhost when running manage.py on the host (see TESTING.md)
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@powercoders.org
SITE_URL=http://localhost:8000

# Slack (optional; leave empty in dev — scheduled tasks in docs/TODO.md)
SLACK_WEBHOOK_URL=

# --- Development only (remove / disable before production — see docs/PRODUCTION_CHECKLIST.md) ---
ENABLE_DEV_SEED=true
# Auto-run create_dev_superuser on docker compose web start (requires DJANGO_SUPERUSER_* below)
CREATE_DEV_SUPERUSER=true

DJANGO_SUPERUSER_EMAIL=admin@dev.powerhub.local
DJANGO_SUPERUSER_DISPLAY_NAME=Admin Dev
DJANGO_SUPERUSER_PASSWORD=admin-dev-powerhub-local
